<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="10dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardUseCompatPadding="true"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="1"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Grower Code  " />

                    <TextView
                        android:id="@+id/tv_grower_code"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Grower Name " />

                    <TextView
                        android:id="@+id/tv_grower_name"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Field Code " />

                    <TextView
                        android:id="@+id/plotcode_txt"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Field Village " />

                    <TextView
                        android:id="@+id/tv_field_village"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />
                </LinearLayout>



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Receipt Number  " />

                    <TextView
                        android:id="@+id/receiptId"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="No of Imported Saplings To Dispatch  " />

                    <TextView
                        android:id="@+id/NoofImportedSaplings_text"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="No of Indigenous Saplings To Dispatch " />

                    <TextView
                        android:id="@+id/noofIndegenoussapling_txt"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="No of Saplings To Dispatch  " />

                    <TextView
                        android:id="@+id/noofsaplingstodispatch_text"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Status  " />

                    <TextView
                        android:id="@+id/status_txt"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pickiup_date_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Exp Date Of Pickup  " />

                    <TextView
                        android:id="@+id/expdateofpick_text"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/commnets_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Comments  " />

                    <TextView
                        android:id="@+id/comments_txt"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Created By: " />

                    <TextView
                        android:id="@+id/createdby_txt"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Created Date : " />

                    <TextView
                        android:id="@+id/createddate_txt"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Updated By " />

                    <TextView
                        android:id="@+id/updatedBy_txt"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="1">
                    <TextView
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.57"
                        android:text="Updated Date " />

                    <TextView
                        android:id="@+id/Updateddate_txt"
                        style="@style/header_h1_text_title_list_item"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.43"/>

                </LinearLayout>
            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:orientation="vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@mipmap/arrow_point_to_right"/>



        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:orientation="vertical">


            <ImageView
                android:id="@+id/ivDeleteRequest"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_cancel"/>

        </LinearLayout>


    </androidx.cardview.widget.CardView>
</RelativeLayout>