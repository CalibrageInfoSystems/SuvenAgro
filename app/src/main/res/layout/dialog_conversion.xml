    <LinearLayout
        android:id="@+id/viewDispatchSaplingDetails"
        style="@style/OptionItemStyle"
        android:background="@drawable/bg_card_green">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/viewdispatch" />

        <TextView
            style="@style/textbasictitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="View Dispatch Sapling Details"
            android:textColor="#000000" />

        <View
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/arrow_right" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/optionConversion"
        style="@style/OptionItemStyle"
        android:background="@drawable/bg_card_green">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/field_conv" />

        <TextView
            style="@style/textbasictitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Field Conversion"
            android:textColor="#000000" />

        <View
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/arrow_right" />
    </LinearLayout>
    <!-- Four options -->


    <LinearLayout
        android:id="@+id/optionretakeboundaries"
