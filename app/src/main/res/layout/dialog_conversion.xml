    <LinearLayout
        android:id="@+id/manageAdvanceDetails"
        style="@style/OptionItemStyle"
        android:background="@drawable/bg_card_green">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/advance_details_icon" />

        <TextView
            style="@style/textbasictitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Plantation DD"
            android:textColor="#000000" />

        <View
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/arrow_right" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/raiseDispatchSaplingsRequest"
        style="@style/OptionItemStyle"
        android:background="@drawable/bg_card_green">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/raise_dispatch_saplings_icon" />

        <TextView
            style="@style/textbasictitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Raise Dispatch Saplings Request"
            android:textColor="#000000" />

        <View
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/arrow_right" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/addDispatchSaplings"
        style="@style/OptionItemStyle"
        android:background="@drawable/bg_card_green">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/dispatch_saplings_icon" />

        <TextView
            style="@style/textbasictitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Add Dispatch Saplings"
            android:textColor="#000000" />

        <View
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/arrow_right" />
    </LinearLayout>
