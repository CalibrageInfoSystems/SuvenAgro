<!-- res/layout/item_advance_details.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="4dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"

                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Grower Code"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_grower_code"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Grower Code"
                    android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"

                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Grower Name" />

                <TextView
                    android:id="@+id/tv_grower_name"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Grower Name" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Field Code" />

                <TextView
                    android:id="@+id/tv_plot_code"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Plot Code"
                    />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"

                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Field Village" />

                <TextView
                    android:id="@+id/tv_field_village"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Village" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Receipt Number" />

                <TextView
                    android:id="@+id/tv_receipt_no"
                    android:layout_width="0dp"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"

                    android:layout_weight="0.5"
                    android:text="Receipt Number"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:id="@+id/ll_survey_number"
                android:visibility="gone"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Survey Number" />

                <TextView
                    android:id="@+id/tv_survey_number"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
android:id="@+id/ll_exp_month_of_Planting"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Exp.Month of Planting" />

                <TextView
                    android:id="@+id/tv_exp_month_of_Planting"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"

                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Amount" />

                <TextView
                    android:id="@+id/tv_amount_received"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Amount" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Advance Received Date" />

                <TextView
                    android:id="@+id/tv_date_received"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Date" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Mode of Payment" />

                <TextView
                    android:id="@+id/tv_paymnet_mode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Mode of Payment"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Plantation Type" />

                <TextView
                    android:id="@+id/tv_plantation_type"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_weight="0.5"
                    android:text="Plantation Type"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Area" />

                <TextView
                    android:id="@+id/tv_area"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Area" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Imported Saplings Issued" />

                <TextView
                    android:id="@+id/tv_imported_saplings_issued"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Saplings" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:id="@+id/ll_indigenous_saplings_issued"
                android:orientation="horizontal"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Indigenous Saplings Issued" />

                <TextView
                    android:id="@+id/tv_indigenous_saplings_issued"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Saplings" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="No of Saplings Advance Paid For"
                    android:textColor="@color/black" />

                <TextView
                    android:id="@+id/tv_saplings_advance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Saplings Advance Paid" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Comments" />

                <TextView
                    android:id="@+id/tv_comments"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_weight="0.5"
                    android:text="Comments"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1"
                >

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:textColor="@color/black"
                    android:text="Created By" />

                <TextView
                    android:id="@+id/tv_created_by"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_weight="0.5"
                    android:text="Created by"/>
            </LinearLayout>


        </LinearLayout>
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center_vertical|end"
            android:src="@mipmap/arrow_point_to_right"/>
    </androidx.cardview.widget.CardView>


</LinearLayout>


