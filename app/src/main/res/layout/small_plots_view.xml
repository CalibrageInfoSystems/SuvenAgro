 <androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    card_view:cardCornerRadius="4dp"
    card_view:cardElevation="4dp"
    card_view:cardUseCompatPadding="true">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/focusable"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="8dp">


        <LinearLayout
            android:id="@+id/RLplotdetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toLeftOf="@+id/chkSelected">

            <!-- Plot ID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Code"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvplotidvalue"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="FieldId"
                    />
            </LinearLayout>

            <!-- Govt Plot ID -->
            <LinearLayout
                android:id="@+id/govt_plot_id_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Government Field Code"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvgvtplotidvalue"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text=""
                 />
            </LinearLayout>

            <!-- Village -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Village "
                    android:textStyle="bold"
                   />
                <TextView
                    android:id="@+id/tvplotvillagevalue"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Village"
                />
            </LinearLayout>

            <!-- Landmark -->
            <LinearLayout
                android:id="@+id/landmark_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Landmark "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvplotlandmarkvalue"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Landmark"
                    android:singleLine="false"
                    android:scrollHorizontally="false"
                    android:breakStrategy="simple"
                   />
            </LinearLayout>

            <!-- Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Total Field Area "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvplotareavalue"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Area"
                   />
            </LinearLayout>

            <!-- Survey Number -->
            <LinearLayout
                android:id="@+id/survey_number_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Survey Number "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvplotsurveyvalue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:text="Field survey number"
                    android:singleLine="false"
                    android:scrollHorizontally="false"
                    android:breakStrategy="simple" />


            </LinearLayout>

            <!-- DOP -->
            <LinearLayout
                android:id="@+id/plotDOP_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Date Of Planting "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvplotDOP"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field DOP"
                    />
            </LinearLayout>

            <!-- Visit Count (hidden) -->
            <LinearLayout
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Visit Count"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/vistCount"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field VisitCount"
                 />
            </LinearLayout>

            <!-- Latest Visit Date -->
            <LinearLayout
                android:id="@+id/lastest_vistDate_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Last CM Visit Date "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/lastest_vistDate"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field LatestDate"
                 />
            </LinearLayout>

            <!-- Latest Harvest Date -->
            <LinearLayout
                android:id="@+id/lastest_harvestDate_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Last Harvesting Date "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/lastest_harvestDate"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field LatestDate"
                   />
            </LinearLayout>

            <!-- Plot Status (hidden) -->
            <LinearLayout
                android:visibility="gone"
                android:id="@+id/plot_status_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text="Field Status "
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/plot_Status"
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    style="@style/header_h1_text_title_list_item"
                    android:layout_height="wrap_content"
                    android:text=""
                  />
            </LinearLayout>
        </LinearLayout>


